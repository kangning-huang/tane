  { "id": "ql-050", "lemma": "静か", "kana": "しずか", "kanji": "静か", "romaji": "shizuka", "part_of_speech": "na-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "安静", "chinese_traditional": "安靜", "basic_japanese_definition": "音がなくて、しずかなこと。", "example_sentences": [{ "jp": "静かな町です。", "kana": "しずかなまちです。", "zh": "是个安静的城镇。" }], "grammar_patterns": ["pt-022"], "chinese_learner_note": "な形容词，修饰名词加 な（静かな町）。反义 にぎやか。", "audio_url": null, "tags": ["na-adjective", "opposite:にぎやか"], "review": "verified" },
