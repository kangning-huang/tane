[
  { "id": "ql-001", "lemma": "大きい", "kana": "おおきい", "kanji": "大きい", "romaji": "ōkii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["大"], "chinese_simplified": "大", "chinese_traditional": "大", "basic_japanese_definition": "形や数がふつうより上であること。", "example_sentences": [{ "jp": "大きい家ですね。", "kana": "おおきいいえですね。", "zh": "好大的房子啊。" }], "grammar_patterns": ["pt-021"], "chinese_learner_note": "反义 小さい。い形容词，否定 大きくない。", "audio_url": null, "tags": ["i-adjective", "opposite:小さい", "core"], "review": "verified" },
  { "id": "ql-002", "lemma": "小さい", "kana": "ちいさい", "kanji": "小さい", "romaji": "chiisai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["小"], "chinese_simplified": "小", "chinese_traditional": "小", "basic_japanese_definition": "形や数がふつうより下であること。", "example_sentences": [{ "jp": "小さい犬がいます。", "kana": "ちいさいいぬがいます。", "zh": "有一只小狗。" }], "grammar_patterns": ["pt-021"], "chinese_learner_note": "反义 大きい。", "audio_url": null, "tags": ["i-adjective", "opposite:大きい", "core"], "review": "verified" },
  { "id": "ql-003", "lemma": "高い", "kana": "たかい", "kanji": "高い", "romaji": "takai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["高"], "chinese_simplified": "高；贵", "chinese_traditional": "高；貴", "basic_japanese_definition": "位置が上であること、またはねだんが大きいこと。", "example_sentences": [{ "jp": "この時計は高いです。", "kana": "このとけいはたかいです。", "zh": "这块表很贵。" }], "grammar_patterns": ["pt-021"], "chinese_learner_note": "兼表「高」与「贵」；「高」的反义是 低い，「贵」的反义是 安い。", "audio_url": null, "tags": ["i-adjective", "opposite:安い", "core"], "review": "verified" },
  { "id": "ql-004", "lemma": "安い", "kana": "やすい", "kanji": "安い", "romaji": "yasui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["安"], "chinese_simplified": "便宜", "chinese_traditional": "便宜", "basic_japanese_definition": "ねだんが小さいこと。", "example_sentences": [{ "jp": "この店は安いです。", "kana": "このみせはやすいです。", "zh": "这家店便宜。" }], "grammar_patterns": ["pt-021"], "chinese_learner_note": "安い 的常用义是「便宜」，不是「安全」；安全 是 安全(あんぜん)。", "audio_url": null, "tags": ["i-adjective", "opposite:高い", "core"], "review": "verified" },
  { "id": "ql-005", "lemma": "低い", "kana": "ひくい", "kanji": "低い", "romaji": "hikui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "低；矮", "chinese_traditional": "低；矮", "basic_japanese_definition": "位置や程度が下であること。", "example_sentences": [{ "jp": "声が低いです。", "kana": "こえがひくいです。", "zh": "声音低。" }], "grammar_patterns": [], "chinese_learner_note": "「个子矮」用 背が低い；是 高い（高）的反义。", "audio_url": null, "tags": ["i-adjective", "opposite:高い"], "review": "verified" },
  { "id": "ql-006", "lemma": "新しい", "kana": "あたらしい", "kanji": "新しい", "romaji": "atarashii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["新"], "chinese_simplified": "新", "chinese_traditional": "新", "basic_japanese_definition": "作られて、または始まってから時間がたっていないこと。", "example_sentences": [{ "jp": "新しい車を買いました。", "kana": "あたらしいくるまをかいました。", "zh": "买了新车。" }], "grammar_patterns": ["pt-021"], "chinese_learner_note": "注意读音 あたらしい（不是 あらたしい）。反义 古い。", "audio_url": null, "tags": ["i-adjective", "opposite:古い", "core"], "review": "verified" },
  { "id": "ql-007", "lemma": "古い", "kana": "ふるい", "kanji": "古い", "romaji": "furui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["古"], "chinese_simplified": "旧；古老", "chinese_traditional": "舊；古老", "basic_japanese_definition": "作られてから時間がたっていること。", "example_sentences": [{ "jp": "古い本を読みます。", "kana": "ふるいほんをよみます。", "zh": "读旧书。" }], "grammar_patterns": [], "chinese_learner_note": "古い 只用于物，不用于人的年龄；说人「年长」用 年上 等。反义 新しい。", "audio_url": null, "tags": ["i-adjective", "opposite:新しい", "core"], "review": "verified" },
  { "id": "ql-008", "lemma": "多い", "kana": "おおい", "kanji": "多い", "romaji": "ōi", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["多"], "chinese_simplified": "多", "chinese_traditional": "多", "basic_japanese_definition": "数や量がたくさんあること。", "example_sentences": [{ "jp": "この町は人が多いです。", "kana": "このまちはひとがおおいです。", "zh": "这个城镇人很多。" }], "grammar_patterns": [], "chinese_learner_note": "多い 一般不直接修饰名词（×多い人），多用「〜が多い」。反义 少ない。", "audio_url": null, "tags": ["i-adjective", "opposite:少ない", "core"], "review": "verified" },
  { "id": "ql-009", "lemma": "少ない", "kana": "すくない", "kanji": "少ない", "romaji": "sukunai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["少"], "chinese_simplified": "少", "chinese_traditional": "少", "basic_japanese_definition": "数や量が小さいこと。", "example_sentences": [{ "jp": "お金が少ないです。", "kana": "おかねがすくないです。", "zh": "钱很少。" }], "grammar_patterns": [], "chinese_learner_note": "与 少し（一点，副词）区分；少ない 是形容词「少的」。反义 多い。", "audio_url": null, "tags": ["i-adjective", "opposite:多い"], "review": "verified" },
  { "id": "ql-010", "lemma": "長い", "kana": "ながい", "kanji": "長い", "romaji": "nagai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["長"], "chinese_simplified": "长", "chinese_traditional": "長", "basic_japanese_definition": "ものや時間がながいこと。", "example_sentences": [{ "jp": "長い手紙を書きました。", "kana": "ながいてがみをかきました。", "zh": "写了很长的信。" }], "grammar_patterns": [], "chinese_learner_note": "反义 短い。", "audio_url": null, "tags": ["i-adjective", "opposite:短い"], "review": "verified" },
  { "id": "ql-011", "lemma": "短い", "kana": "みじかい", "kanji": "短い", "romaji": "mijikai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "短", "chinese_traditional": "短", "basic_japanese_definition": "ものや時間がみじかいこと。", "example_sentences": [{ "jp": "短い時間でした。", "kana": "みじかいじかんでした。", "zh": "是很短的时间。" }], "grammar_patterns": [], "chinese_learner_note": "反义 長い。", "audio_url": null, "tags": ["i-adjective", "opposite:長い"], "review": "verified" },
  { "id": "ql-012", "lemma": "速い", "kana": "はやい", "kanji": "速い", "romaji": "hayai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "（速度）快", "chinese_traditional": "（速度）快", "basic_japanese_definition": "動きや進みかたがはやいこと。", "example_sentences": [{ "jp": "新幹線は速いです。", "kana": "しんかんせんははやいです。", "zh": "新干线很快。" }], "grammar_patterns": [], "chinese_learner_note": "「速度快」用 速い；「时间早」用 早い（同音 はやい）。反义 遅い。", "audio_url": null, "tags": ["i-adjective", "opposite:遅い"], "review": "verified" },
  { "id": "ql-013", "lemma": "早い", "kana": "はやい", "kanji": "早い", "romaji": "hayai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "（时间）早", "chinese_traditional": "（時間）早", "basic_japanese_definition": "時間や時こくがはやいこと。", "example_sentences": [{ "jp": "今日は早く起きました。", "kana": "きょうははやくおきました。", "zh": "今天起得早。" }], "grammar_patterns": [], "chinese_learner_note": "「时间早」早い ↔「速度快」速い，同音 はやい，靠汉字区分。反义 遅い。", "audio_url": null, "tags": ["i-adjective", "opposite:遅い"], "review": "verified" },
  { "id": "ql-014", "lemma": "遅い", "kana": "おそい", "kanji": "遅い", "romaji": "osoi", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "慢；晚", "chinese_traditional": "慢；晚", "basic_japanese_definition": "動きがゆっくり、または時こくがおそいこと。", "example_sentences": [{ "jp": "もう遅いから、帰ります。", "kana": "もうおそいから、かえります。", "zh": "已经晚了，我回去了。" }], "grammar_patterns": [], "chinese_learner_note": "一词兼表「慢」与「晚」，是 速い 和 早い 共同的反义。", "audio_url": null, "tags": ["i-adjective", "opposite:早い"], "review": "verified" },
  { "id": "ql-015", "lemma": "暑い", "kana": "あつい", "kanji": "暑い", "romaji": "atsui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "（天气）热", "chinese_traditional": "（天氣）熱", "basic_japanese_definition": "気温が高くてあついこと。", "example_sentences": [{ "jp": "今日はとても暑いです。", "kana": "きょうはとてもあついです。", "zh": "今天很热。" }], "grammar_patterns": [], "chinese_learner_note": "天气热用 暑い；东西烫用 熱い（同音 あつい），汉字不同。反义 寒い。", "audio_url": null, "tags": ["i-adjective", "weather", "opposite:寒い"], "review": "verified" },
  { "id": "ql-016", "lemma": "寒い", "kana": "さむい", "kanji": "寒い", "romaji": "samui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "（天气）冷", "chinese_traditional": "（天氣）冷", "basic_japanese_definition": "気温が低くてさむいこと。", "example_sentences": [{ "jp": "冬は寒いです。", "kana": "ふゆはさむいです。", "zh": "冬天很冷。" }], "grammar_patterns": [], "chinese_learner_note": "天气冷用 寒い；东西凉用 冷たい。反义 暑い。", "audio_url": null, "tags": ["i-adjective", "weather", "opposite:暑い"], "review": "verified" },
  { "id": "ql-017", "lemma": "熱い", "kana": "あつい", "kanji": "熱い", "romaji": "atsui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "（物体）烫；热", "chinese_traditional": "（物體）燙；熱", "basic_japanese_definition": "ものの温度が高いこと。", "example_sentences": [{ "jp": "熱いお茶を飲みます。", "kana": "あついおちゃをのみます。", "zh": "喝热茶。" }], "grammar_patterns": [], "chinese_learner_note": "物体烫用 熱い；天气热用 暑い。反义 冷たい。", "audio_url": null, "tags": ["i-adjective", "opposite:冷たい"], "review": "verified" },
  { "id": "ql-018", "lemma": "冷たい", "kana": "つめたい", "kanji": "冷たい", "romaji": "tsumetai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "凉；冷淡", "chinese_traditional": "涼；冷淡", "basic_japanese_definition": "ものの温度が低いこと。人の態度にも使う。", "example_sentences": [{ "jp": "冷たい水をください。", "kana": "つめたいみずをください。", "zh": "请给我凉水。" }], "grammar_patterns": [], "chinese_learner_note": "东西凉用 冷たい；天气冷用 寒い。也形容人「冷淡」。", "audio_url": null, "tags": ["i-adjective", "opposite:熱い"], "review": "verified" },
  { "id": "ql-019", "lemma": "いい", "kana": "いい", "kanji": null, "romaji": "ii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "好", "chinese_traditional": "好", "basic_japanese_definition": "よいこと。「よい」のふつうの言い方。", "example_sentences": [{ "jp": "いい天気ですね。", "kana": "いいてんきですね。", "zh": "天气真好。" }], "grammar_patterns": ["pt-033"], "chinese_learner_note": "活用要用 よい 的词根：よくない（否定）、よかった（过去），不说 いくない/いかった。反义 悪い。", "audio_url": null, "tags": ["i-adjective", "opposite:悪い", "core", "irregular"], "review": "verified" },
  { "id": "ql-020", "lemma": "悪い", "kana": "わるい", "kanji": "悪い", "romaji": "warui", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "坏；不好", "chinese_traditional": "壞；不好", "basic_japanese_definition": "よくないこと。", "example_sentences": [{ "jp": "天気が悪いです。", "kana": "てんきがわるいです。", "zh": "天气不好。" }], "grammar_patterns": [], "chinese_learner_note": "口语「悪い（ね）」也用作轻微道歉「不好意思」。反义 いい。", "audio_url": null, "tags": ["i-adjective", "opposite:いい", "core"], "review": "verified" },
  { "id": "ql-021", "lemma": "面白い", "kana": "おもしろい", "kanji": "面白い", "romaji": "omoshiroi", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "i-adjective", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "有趣；好玩", "chinese_traditional": "有趣；好玩", "basic_japanese_definition": "見たり聞いたりして、楽しい・おもしろいこと。", "example_sentences": [{ "jp": "この映画は面白いです。", "kana": "このえいがはおもしろいです。", "zh": "这部电影很有意思。" }], "grammar_patterns": [], "chinese_learner_note": "兼表「有趣」与「滑稽好笑」。反义 つまらない。", "audio_url": null, "tags": ["i-adjective", "opposite:つまらない", "core"], "review": "verified" },
  { "id": "ql-022", "lemma": "つまらない", "kana": "つまらない", "kanji": null, "romaji": "tsumaranai", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "i-adjective", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "无聊；没意思", "chinese_traditional": "無聊；沒意思", "basic_japanese_definition": "おもしろくないこと。", "example_sentences": [{ "jp": "この本はつまらないです。", "kana": "このほんはつまらないです。", "zh": "这本书没意思。" }], "grammar_patterns": [], "chinese_learner_note": "形似否定但本身就是一个形容词（不是 つまる 的否定）。反义 面白い。", "audio_url": null, "tags": ["i-adjective", "opposite:面白い"], "review": "verified" },
  { "id": "ql-023", "lemma": "楽しい", "kana": "たのしい", "kanji": "楽しい", "romaji": "tanoshii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "i-adjective", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "快乐；开心", "chinese_traditional": "快樂；開心", "basic_japanese_definition": "していて心が楽しいこと。", "example_sentences": [{ "jp": "旅行は楽しかったです。", "kana": "りょこうはたのしかったです。", "zh": "旅行很开心。" }], "grammar_patterns": [], "chinese_learner_note": "楽しい 指「（做某事）开心」；うれしい 指「（因某事）高兴」。", "audio_url": null, "tags": ["i-adjective"], "review": "verified" },
  { "id": "ql-024", "lemma": "うれしい", "kana": "うれしい", "kanji": null, "romaji": "ureshii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "高兴；开心", "chinese_traditional": "高興；開心", "basic_japanese_definition": "いいことがあって、心がうれしいこと。", "example_sentences": [{ "jp": "プレゼントをもらって、うれしいです。", "kana": "プレゼントをもらって、うれしいです。", "zh": "收到礼物很高兴。" }], "grammar_patterns": [], "chinese_learner_note": "うれしい 是一时的高兴；楽しい 是持续的快乐。反义 悲しい。", "audio_url": null, "tags": ["i-adjective", "emotion", "opposite:悲しい"], "review": "verified" },
  { "id": "ql-025", "lemma": "悲しい", "kana": "かなしい", "kanji": "悲しい", "romaji": "kanashii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "悲伤；难过", "chinese_traditional": "悲傷；難過", "basic_japanese_definition": "つらいことがあって、心がかなしいこと。", "example_sentences": [{ "jp": "悲しい映画でした。", "kana": "かなしいえいがでした。", "zh": "是部悲伤的电影。" }], "grammar_patterns": [], "chinese_learner_note": "反义 うれしい。", "audio_url": null, "tags": ["i-adjective", "emotion", "opposite:うれしい"], "review": "verified" },
  { "id": "ql-026", "lemma": "おいしい", "kana": "おいしい", "kanji": null, "romaji": "oishii", "part_of_speech": "i-adjective", "category": "qualities", "subcategory": "opposites", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "好吃；好喝", "chinese_traditional": "好吃；好喝", "basic_japanese_definition": "食べものや飲みものの味がいいこと。", "example_sentences": [{ "jp": "このケーキはおいしいです。", "kana": "このケーキはおいしいです。", "zh": "这个蛋糕很好吃。" }], "grammar_patterns": [], "chinese_learner_note": "男性口语也说 うまい。反义 まずい。", "audio_url": null, "tags": ["i-adjective", "food", "opposite:まずい", "core"], "review": "verified" },
