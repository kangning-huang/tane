[
  { "id": "fx-001", "lemma": "こんにちは", "kana": "こんにちは", "kanji": null, "romaji": "konnichiwa", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "你好（白天）", "chinese_traditional": "你好（白天）", "basic_japanese_definition": "昼間のあいさつの言葉。", "example_sentences": [{ "jp": "こんにちは。いいお天気ですね。", "kana": "こんにちは。いいおてんきですね。", "zh": "你好，天气真好啊。" }], "grammar_patterns": [], "chinese_learner_note": "结尾的 は 读 wa（不读 ha）；白天用。早上 おはよう、晚上 こんばんは。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-002", "lemma": "おはようございます", "kana": "おはようございます", "kanji": null, "romaji": "ohayō gozaimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "早上好", "chinese_traditional": "早上好", "basic_japanese_definition": "朝のあいさつの言葉。", "example_sentences": [{ "jp": "おはようございます。", "kana": "おはようございます。", "zh": "早上好。" }], "grammar_patterns": [], "chinese_learner_note": "亲近的人之间可省略成 おはよう；加 ございます 更礼貌。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-003", "lemma": "こんばんは", "kana": "こんばんは", "kanji": null, "romaji": "konbanwa", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "晚上好", "chinese_traditional": "晚上好", "basic_japanese_definition": "夜のあいさつの言葉。", "example_sentences": [{ "jp": "こんばんは。", "kana": "こんばんは。", "zh": "晚上好。" }], "grammar_patterns": [], "chinese_learner_note": "结尾 は 读 wa；与「晚安（睡前）おやすみなさい」不同。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-004", "lemma": "さようなら", "kana": "さようなら", "kanji": null, "romaji": "sayōnara", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "再见", "chinese_traditional": "再見", "basic_japanese_definition": "わかれるときのあいさつの言葉。", "example_sentences": [{ "jp": "さようなら。また明日。", "kana": "さようなら。またあした。", "zh": "再见，明天见。" }], "grammar_patterns": [], "chinese_learner_note": "略带郑重/长别意味；朋友间日常告别更常说 じゃ(あ)ね・またね・バイバイ。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-005", "lemma": "ありがとうございます", "kana": "ありがとうございます", "kanji": null, "romaji": "arigatō gozaimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "谢谢", "chinese_traditional": "謝謝", "basic_japanese_definition": "お礼を言うときの言葉。", "example_sentences": [{ "jp": "本当にありがとうございます。", "kana": "ほんとうにありがとうございます。", "zh": "真的非常感谢。" }], "grammar_patterns": [], "chinese_learner_note": "随意场合可说 ありがとう；对已发生的事道谢可用过去形 ありがとうございました。", "audio_url": null, "tags": ["courtesy", "core"], "review": "verified" },
  { "id": "fx-006", "lemma": "すみません", "kana": "すみません", "kanji": null, "romaji": "sumimasen", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "对不起；不好意思；劳驾", "chinese_traditional": "對不起；不好意思；勞駕", "basic_japanese_definition": "あやまるとき、人に声をかけるとき、軽くお礼を言うときに使う言葉。", "example_sentences": [{ "jp": "すみません、駅はどこですか。", "kana": "すみません、えきはどこですか。", "zh": "不好意思，车站在哪里？" }], "grammar_patterns": [], "chinese_learner_note": "万能词：道歉、搭话（劳驾）、轻度致谢都能用；口语也说 すいません。", "audio_url": null, "tags": ["courtesy", "core"], "review": "verified" },
  { "id": "fx-007", "lemma": "ごめんなさい", "kana": "ごめんなさい", "kanji": null, "romaji": "gomen nasai", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "对不起", "chinese_traditional": "對不起", "basic_japanese_definition": "あやまるときの言葉。", "example_sentences": [{ "jp": "遅れて、ごめんなさい。", "kana": "おくれて、ごめんなさい。", "zh": "对不起，我迟到了。" }], "grammar_patterns": [], "chinese_learner_note": "纯道歉用 ごめんなさい；すみません 还能搭话/致谢。亲近时说 ごめん。", "audio_url": null, "tags": ["courtesy", "core"], "review": "verified" },
  { "id": "fx-008", "lemma": "お願いします", "kana": "おねがいします", "kanji": "お願いします", "romaji": "onegai shimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "request-response", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "拜托了；麻烦您", "chinese_traditional": "拜託了；麻煩您", "basic_japanese_definition": "人に何かをたのむときのていねいな言葉。", "example_sentences": [{ "jp": "これをお願いします。", "kana": "これをおねがいします。", "zh": "这个就拜托您了。" }], "grammar_patterns": [], "chinese_learner_note": "点餐/办事时「Nをお願いします」很常用，相当于「我要…/麻烦给我…」。", "audio_url": null, "tags": ["request-response", "core"], "review": "verified" },
  { "id": "fx-009", "lemma": "いただきます", "kana": "いただきます", "kanji": null, "romaji": "itadakimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "我开动了（饭前）", "chinese_traditional": "我開動了（飯前）", "basic_japanese_definition": "食べる前に言うあいさつの言葉。", "example_sentences": [{ "jp": "いただきます。", "kana": "いただきます。", "zh": "我开动了。" }], "grammar_patterns": [], "chinese_learner_note": "饭前固定说，表示对食物与做饭人的感谢；中文没有对应习惯，需整体记。", "audio_url": null, "tags": ["courtesy", "culture", "core"], "review": "verified" },
  { "id": "fx-010", "lemma": "ごちそうさまでした", "kana": "ごちそうさまでした", "kanji": null, "romaji": "gochisōsama deshita", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "我吃饱了；多谢款待（饭后）", "chinese_traditional": "我吃飽了；多謝款待（飯後）", "basic_japanese_definition": "食べたあとに言うあいさつの言葉。", "example_sentences": [{ "jp": "ごちそうさまでした。", "kana": "ごちそうさまでした。", "zh": "多谢款待，我吃好了。" }], "grammar_patterns": [], "chinese_learner_note": "与 いただきます 配对，饭后说；随意场合可省成 ごちそうさま。", "audio_url": null, "tags": ["courtesy", "culture"], "review": "verified" },
  { "id": "fx-011", "lemma": "はじめまして", "kana": "はじめまして", "kanji": null, "romaji": "hajimemashite", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "初次见面（你好）", "chinese_traditional": "初次見面（你好）", "basic_japanese_definition": "はじめて会う人に言うあいさつの言葉。", "example_sentences": [{ "jp": "はじめまして。田中です。", "kana": "はじめまして。たなかです。", "zh": "初次见面，我是田中。" }], "grammar_patterns": [], "chinese_learner_note": "自我介绍开头用；通常接「（名前）です」并以 よろしくお願いします 收尾。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-012", "lemma": "よろしくお願いします", "kana": "よろしくおねがいします", "kanji": "よろしくお願いします", "romaji": "yoroshiku onegai shimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "请多关照", "chinese_traditional": "請多關照", "basic_japanese_definition": "これからの付き合いをおねがいするあいさつの言葉。", "example_sentences": [{ "jp": "どうぞよろしくお願いします。", "kana": "どうぞよろしくおねがいします。", "zh": "请多多关照。" }], "grammar_patterns": [], "chinese_learner_note": "自我介绍结尾、拜托事情时都用；中文「请多关照」最接近，但适用范围更广。", "audio_url": null, "tags": ["courtesy", "core"], "review": "verified" },
  { "id": "fx-013", "lemma": "おやすみなさい", "kana": "おやすみなさい", "kanji": null, "romaji": "oyasumi nasai", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "晚安（睡前）", "chinese_traditional": "晚安（睡前）", "basic_japanese_definition": "ねる前に言うあいさつの言葉。", "example_sentences": [{ "jp": "では、おやすみなさい。", "kana": "では、おやすみなさい。", "zh": "那么，晚安。" }], "grammar_patterns": [], "chinese_learner_note": "睡前/道别用；亲近时说 おやすみ。与「晚上好 こんばんは」不同。", "audio_url": null, "tags": ["greeting", "core"], "review": "verified" },
  { "id": "fx-014", "lemma": "いってきます", "kana": "いってきます", "kanji": null, "romaji": "ittekimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "我走了（去去就回）", "chinese_traditional": "我走了（去去就回）", "basic_japanese_definition": "家などを出るときに言うあいさつの言葉。", "example_sentences": [{ "jp": "いってきます。", "kana": "いってきます。", "zh": "我出门了。" }], "grammar_patterns": [], "chinese_learner_note": "离家外出时说，字面「去了就回来」；对方回 いってらっしゃい。", "audio_url": null, "tags": ["greeting", "culture"], "review": "verified" },
  { "id": "fx-015", "lemma": "いってらっしゃい", "kana": "いってらっしゃい", "kanji": null, "romaji": "itterasshai", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "路上小心；慢走", "chinese_traditional": "路上小心；慢走", "basic_japanese_definition": "出かける人におくる言葉。", "example_sentences": [{ "jp": "いってらっしゃい。", "kana": "いってらっしゃい。", "zh": "慢走。" }], "grammar_patterns": [], "chinese_learner_note": "送别外出者时说，是 いってきます 的回应。", "audio_url": null, "tags": ["greeting", "culture"], "review": "verified" },
  { "id": "fx-016", "lemma": "ただいま", "kana": "ただいま", "kanji": null, "romaji": "tadaima", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "我回来了", "chinese_traditional": "我回來了", "basic_japanese_definition": "家にかえったときに言うあいさつの言葉。", "example_sentences": [{ "jp": "ただいま。", "kana": "ただいま。", "zh": "我回来了。" }], "grammar_patterns": [], "chinese_learner_note": "回家时说；对方回 おかえりなさい。ただいま 也有「现在/马上」的副词义。", "audio_url": null, "tags": ["greeting", "culture"], "review": "verified" },
  { "id": "fx-017", "lemma": "おかえりなさい", "kana": "おかえりなさい", "kanji": null, "romaji": "okaeri nasai", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "你回来啦", "chinese_traditional": "你回來啦", "basic_japanese_definition": "かえってきた人にむかえて言う言葉。", "example_sentences": [{ "jp": "おかえりなさい。", "kana": "おかえりなさい。", "zh": "你回来啦。" }], "grammar_patterns": [], "chinese_learner_note": "迎接回家者时说，是 ただいま 的回应；亲近时说 おかえり。", "audio_url": null, "tags": ["greeting", "culture"], "review": "verified" },
  { "id": "fx-018", "lemma": "お元気ですか", "kana": "おげんきですか", "kanji": "お元気ですか", "romaji": "ogenki desu ka", "part_of_speech": "expression", "category": "expressions", "subcategory": "greeting", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "你好吗？（近来可好）", "chinese_traditional": "你好嗎？（近來可好）", "basic_japanese_definition": "相手の体や気もちがいいかどうかをたずねるあいさつ。", "example_sentences": [{ "jp": "お久しぶりです。お元気ですか。", "kana": "おひさしぶりです。おげんきですか。", "zh": "好久不见，你好吗？" }], "grammar_patterns": [], "chinese_learner_note": "用于久未见面时，不是每天见面的寒暄；天天见的人不必问。回答可用 はい、元気です。", "audio_url": null, "tags": ["greeting"], "review": "verified" },
  { "id": "fx-019", "lemma": "どういたしまして", "kana": "どういたしまして", "kanji": null, "romaji": "dō itashimashite", "part_of_speech": "expression", "category": "expressions", "subcategory": "request-response", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "不客气", "chinese_traditional": "不客氣", "basic_japanese_definition": "お礼を言われたときに返す言葉。", "example_sentences": [{ "jp": "「ありがとう。」「どういたしまして。」", "kana": "「ありがとう。」「どういたしまして。」", "zh": "「谢谢。」「不客气。」" }], "grammar_patterns": [], "chinese_learner_note": "对「谢谢」的回应；日常也常用 いえいえ 等更轻松的说法。", "audio_url": null, "tags": ["request-response"], "review": "verified" },
  { "id": "fx-020", "lemma": "失礼します", "kana": "しつれいします", "kanji": "失礼します", "romaji": "shitsurei shimasu", "part_of_speech": "expression", "category": "expressions", "subcategory": "courtesy", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "打扰了；失陪了；告辞", "chinese_traditional": "打擾了；失陪了；告辭", "basic_japanese_definition": "部屋に入る・出るとき、先に帰るときなどに言うていねいな言葉。", "example_sentences": [{ "jp": "お先に失礼します。", "kana": "おさきにしつれいします。", "zh": "我先告辞了。" }], "grammar_patterns": [], "chinese_learner_note": "进出房间、先行离开、挂电话前等都可用；比 すみません 更正式。过去形 失礼しました 用于道歉。", "audio_url": null, "tags": ["courtesy"], "review": "verified" }
]
