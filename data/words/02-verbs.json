[
  { "id": "vb-001", "lemma": "する", "kana": "する", "kanji": null, "romaji": "suru", "part_of_speech": "verb-suru", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "做；干", "chinese_traditional": "做；幹", "basic_japanese_definition": "ある動作や仕事をおこなう、いちばん基本の動詞。", "example_sentences": [{ "jp": "宿題をします。", "kana": "しゅくだいをします。", "zh": "做作业。" }, { "jp": "勉強します。", "kana": "べんきょうします。", "zh": "学习。" }], "grammar_patterns": ["pt-015"], "chinese_learner_note": "不规则动词（する→します→して→した）。大量名词＋する构成动词（勉強する・電話する），构句能力极强。", "audio_url": null, "tags": ["verb", "core", "irregular"], "review": "verified" },
  { "id": "vb-002", "lemma": "ある", "kana": "ある", "kanji": null, "romaji": "aru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "existence-state", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "有；在（无生命）", "chinese_traditional": "有；在（無生命）", "basic_japanese_definition": "ものや事がそこに存在することをあらわす動詞。", "example_sentences": [{ "jp": "机の上に本があります。", "kana": "つくえのうえにほんがあります。", "zh": "桌上有书。" }], "grammar_patterns": ["pt-007"], "chinese_learner_note": "无生命物/植物/抽象事物用 ある，人和动物用 いる。否定是 ない（不规则，不说 あらない）。", "audio_url": null, "tags": ["verb", "existence", "core"], "review": "verified" },
  { "id": "vb-003", "lemma": "いる", "kana": "いる", "kanji": null, "romaji": "iru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "existence-state", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "有；在（有生命）", "chinese_traditional": "有；在（有生命）", "basic_japanese_definition": "人や動物がそこに存在することをあらわす動詞。", "example_sentences": [{ "jp": "教室に先生がいます。", "kana": "きょうしつにせんせいがいます。", "zh": "教室里有老师。" }], "grammar_patterns": ["pt-008"], "chinese_learner_note": "有生命者用 いる；与 ある 的区别只在「有无生命」。注意与「要る（需要）」同音不同义。", "audio_url": null, "tags": ["verb", "existence", "core"], "review": "verified" },
  { "id": "vb-004", "lemma": "なる", "kana": "なる", "kanji": null, "romaji": "naru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "change-result", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "变成；成为", "chinese_traditional": "變成；成為", "basic_japanese_definition": "あるじょうたいにかわることをあらわす動詞。", "example_sentences": [{ "jp": "春になりました。", "kana": "はるになりました。", "zh": "到春天了。" }], "grammar_patterns": ["pt-050"], "chinese_learner_note": "い形容词＋く＋なる、な形容词/名词＋に＋なる。表自然变化，构句力强。", "audio_url": null, "tags": ["verb", "change", "core"], "review": "verified" },
  { "id": "vb-005", "lemma": "行く", "kana": "いく", "kanji": "行く", "romaji": "iku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["行"], "chinese_simplified": "去", "chinese_traditional": "去", "basic_japanese_definition": "今いるところからべつのところへ動くことをあらわす動詞。", "example_sentences": [{ "jp": "学校へ行きます。", "kana": "がっこうへいきます。", "zh": "去学校。" }], "grammar_patterns": ["pt-011"], "chinese_learner_note": "て形不规则：行って（不是 行いて）。以说话人为中心「离开」用 行く，「靠近」用 来る。", "audio_url": null, "tags": ["verb", "motion", "core"], "review": "verified" },
  { "id": "vb-006", "lemma": "来る", "kana": "くる", "kanji": "来る", "romaji": "kuru", "part_of_speech": "verb-kuru", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["来"], "chinese_simplified": "来", "chinese_traditional": "來", "basic_japanese_definition": "べつのところからこちらへ動くことをあらわす動詞。", "example_sentences": [{ "jp": "友達が家に来ます。", "kana": "ともだちがいえにきます。", "zh": "朋友来家里。" }], "grammar_patterns": [], "chinese_learner_note": "不规则动词：来る・来ます(きます)・来ない(こない)・来て(きて)，读音随活用变。", "audio_url": null, "tags": ["verb", "motion", "core", "irregular"], "review": "verified" },
  { "id": "vb-007", "lemma": "帰る", "kana": "かえる", "kanji": "帰る", "romaji": "kaeru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "回（家）；回去", "chinese_traditional": "回（家）；回去", "basic_japanese_definition": "もといた所、とくに家へもどることをあらわす動詞。", "example_sentences": [{ "jp": "六時に家へ帰ります。", "kana": "ろくじにいえへかえります。", "zh": "六点回家。" }], "grammar_patterns": [], "chinese_learner_note": "形似一段动词但其实是五段（帰ります・帰って）；这类「例外五段」还有 入る・走る・知る・切る。", "audio_url": null, "tags": ["verb", "motion", "core"], "review": "verified" },
  { "id": "vb-008", "lemma": "歩く", "kana": "あるく", "kanji": "歩く", "romaji": "aruku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "走（路）", "chinese_traditional": "走（路）", "basic_japanese_definition": "足でゆっくり前へ進むことをあらわす動詞。", "example_sentences": [{ "jp": "駅まで歩きます。", "kana": "えきまであるきます。", "zh": "走到车站。" }], "grammar_patterns": [], "chinese_learner_note": "「走（步行）」是 歩く；中文「走」≠日语「走る（跑）」。", "audio_url": null, "tags": ["verb", "motion"], "review": "verified" },
  { "id": "vb-009", "lemma": "走る", "kana": "はしる", "kanji": "走る", "romaji": "hashiru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "跑", "chinese_traditional": "跑", "basic_japanese_definition": "足ではやく前へ進むことをあらわす動詞。", "example_sentences": [{ "jp": "公園を走ります。", "kana": "こうえんをはしります。", "zh": "在公园跑步。" }], "grammar_patterns": [], "chinese_learner_note": "走る＝跑（≠中文「走」）；是「例外五段」动词。", "audio_url": null, "tags": ["verb", "motion"], "review": "verified" },
  { "id": "vb-010", "lemma": "乗る", "kana": "のる", "kanji": "乗る", "romaji": "noru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "乘；坐（车）", "chinese_traditional": "乘；坐（車）", "basic_japanese_definition": "電車や車などにのることをあらわす動詞。", "example_sentences": [{ "jp": "電車に乗ります。", "kana": "でんしゃにのります。", "zh": "坐电车。" }], "grammar_patterns": [], "chinese_learner_note": "乘坐的交通工具用 に（电车に乗る），不用 を。反义是 降りる。", "audio_url": null, "tags": ["verb", "motion"], "review": "verified" },
  { "id": "vb-011", "lemma": "降りる", "kana": "おりる", "kanji": "降りる", "romaji": "oriru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "下（车）；下来", "chinese_traditional": "下（車）；下來", "basic_japanese_definition": "乗りものや高いところからおりることをあらわす動詞。", "example_sentences": [{ "jp": "次の駅で降ります。", "kana": "つぎのえきでおります。", "zh": "在下一站下车。" }], "grammar_patterns": [], "chinese_learner_note": "从交通工具下来用 を（電車を降りる）；与 乗る 成对。", "audio_url": null, "tags": ["verb", "motion"], "review": "verified" },
  { "id": "vb-012", "lemma": "見る", "kana": "みる", "kanji": "見る", "romaji": "miru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["見"], "chinese_simplified": "看", "chinese_traditional": "看", "basic_japanese_definition": "目でものを見ることをあらわす動詞。", "example_sentences": [{ "jp": "テレビを見ます。", "kana": "テレビをみます。", "zh": "看电视。" }], "grammar_patterns": [], "chinese_learner_note": "見る＝主动看；見える＝（自然）看得见；見せる＝给别人看，三者区分。", "audio_url": null, "tags": ["verb", "perception", "core"], "review": "verified" },
  { "id": "vb-013", "lemma": "聞く", "kana": "きく", "kanji": "聞く", "romaji": "kiku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["聞"], "chinese_simplified": "听；问", "chinese_traditional": "聽；問", "basic_japanese_definition": "耳で音を聞く、または人に質問することをあらわす動詞。", "example_sentences": [{ "jp": "音楽を聞きます。", "kana": "おんがくをききます。", "zh": "听音乐。" }, { "jp": "先生に聞きます。", "kana": "せんせいにききます。", "zh": "问老师。" }], "grammar_patterns": [], "chinese_learner_note": "一词兼「听」和「问」：人に聞く＝问人。聞こえる＝（自然）听得见。", "audio_url": null, "tags": ["verb", "perception", "core"], "review": "verified" },
  { "id": "vb-014", "lemma": "思う", "kana": "おもう", "kanji": "思う", "romaji": "omou", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "想；认为；觉得", "chinese_traditional": "想；認為；覺得", "basic_japanese_definition": "心の中である考えをもつことをあらわす動詞。", "example_sentences": [{ "jp": "明日は晴れると思います。", "kana": "あしたははれるとおもいます。", "zh": "我觉得明天会晴。" }], "grammar_patterns": ["pt-038"], "chinese_learner_note": "「〜と思う」表看法，と前用普通形；考える 偏「思考/动脑」，思う 偏「感觉/认为」。", "audio_url": null, "tags": ["verb", "cognition", "core"], "review": "verified" },
  { "id": "vb-015", "lemma": "知る", "kana": "しる", "kanji": "知る", "romaji": "shiru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "知道；认识", "chinese_traditional": "知道；認識", "basic_japanese_definition": "あることがらを情報として持つことをあらわす動詞。", "example_sentences": [{ "jp": "彼の名前を知っています。", "kana": "かれのなまえをしっています。", "zh": "我知道他的名字。" }], "grammar_patterns": ["pt-018"], "chinese_learner_note": "「知道」用现在进行体 知っています（状态）；否定却用 知りません（不说 知っていません）。", "audio_url": null, "tags": ["verb", "cognition", "core"], "review": "verified" },
  { "id": "vb-016", "lemma": "分かる", "kana": "わかる", "kanji": "分かる", "romaji": "wakaru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["分"], "chinese_simplified": "明白；懂", "chinese_traditional": "明白；懂", "basic_japanese_definition": "ものごとの意味がはっきりすることをあらわす動詞。", "example_sentences": [{ "jp": "日本語が分かります。", "kana": "にほんごがわかります。", "zh": "懂日语。" }], "grammar_patterns": [], "chinese_learner_note": "对象用 が（×日本語を分かる）；分かる 表「自然就懂」，与「知る（获取信息）」不同。", "audio_url": null, "tags": ["verb", "cognition", "core"], "review": "verified" },
  { "id": "vb-017", "lemma": "考える", "kana": "かんがえる", "kanji": "考える", "romaji": "kangaeru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "思考；考虑", "chinese_traditional": "思考；考慮", "basic_japanese_definition": "あたまをつかって、いろいろ考えることをあらわす動詞。", "example_sentences": [{ "jp": "よく考えてください。", "kana": "よくかんがえてください。", "zh": "请好好考虑。" }], "grammar_patterns": [], "chinese_learner_note": "考える＝主动动脑思考；思う＝持有看法/感觉。注意 考える≠中文「考（试）」。", "audio_url": null, "tags": ["verb", "cognition"], "review": "verified" },
  { "id": "vb-018", "lemma": "覚える", "kana": "おぼえる", "kanji": "覚える", "romaji": "oboeru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "记住；学会", "chinese_traditional": "記住；學會", "basic_japanese_definition": "あたらしいことを頭に入れることをあらわす動詞。", "example_sentences": [{ "jp": "新しい言葉を覚えます。", "kana": "あたらしいことばをおぼえます。", "zh": "记新单词。" }], "grammar_patterns": [], "chinese_learner_note": "覚える＝记住（往脑里放）；与 忘れる（忘记）成对。「记得（保持记忆）」用 覚えている。", "audio_url": null, "tags": ["verb", "cognition"], "review": "verified" },
  { "id": "vb-019", "lemma": "忘れる", "kana": "わすれる", "kanji": "忘れる", "romaji": "wasureru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "perception-cognition", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "忘记；遗忘", "chinese_traditional": "忘記；遺忘", "basic_japanese_definition": "覚えていたことを思い出せなくなることをあらわす動詞。", "example_sentences": [{ "jp": "宿題を忘れました。", "kana": "しゅくだいをわすれました。", "zh": "忘了作业。" }], "grammar_patterns": [], "chinese_learner_note": "也表「遗落（物品）」：かさを忘れた＝把伞落下了。", "audio_url": null, "tags": ["verb", "cognition"], "review": "verified" },
  { "id": "vb-020", "lemma": "言う", "kana": "いう", "kanji": "言う", "romaji": "iu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["言"], "chinese_simplified": "说；叫做", "chinese_traditional": "說；叫做", "basic_japanese_definition": "言葉を口に出すことをあらわす動詞。", "example_sentences": [{ "jp": "もう一度言ってください。", "kana": "もういちどいってください。", "zh": "请再说一遍。" }], "grammar_patterns": ["pt-039"], "chinese_learner_note": "口语常读 ゆう；「〜という」＝叫做…/所谓…。引用用「〜と言う」。", "audio_url": null, "tags": ["verb", "communication", "core"], "review": "verified" },
  { "id": "vb-021", "lemma": "話す", "kana": "はなす", "kanji": "話す", "romaji": "hanasu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["話"], "chinese_simplified": "说话；交谈", "chinese_traditional": "說話；交談", "basic_japanese_definition": "人と言葉でやりとりすることをあらわす動詞。", "example_sentences": [{ "jp": "日本語で話します。", "kana": "にほんごではなします。", "zh": "用日语交谈。" }], "grammar_patterns": [], "chinese_learner_note": "话す 偏「交谈、讲述」；言う 偏「说出某话」。语言用 で（日本語で話す）。", "audio_url": null, "tags": ["verb", "communication", "core"], "review": "verified" },
  { "id": "vb-022", "lemma": "読む", "kana": "よむ", "kanji": "読む", "romaji": "yomu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["読"], "chinese_simplified": "读；看（书）", "chinese_traditional": "讀；看（書）", "basic_japanese_definition": "文字を見て、意味をとることをあらわす動詞。", "example_sentences": [{ "jp": "新聞を読みます。", "kana": "しんぶんをよみます。", "zh": "看报纸。" }], "grammar_patterns": [], "chinese_learner_note": "「看书」用 読む（不是 見る）；見る 用于看影像/景物。", "audio_url": null, "tags": ["verb", "communication", "core"], "review": "verified" },
  { "id": "vb-023", "lemma": "書く", "kana": "かく", "kanji": "書く", "romaji": "kaku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["書"], "chinese_simplified": "写", "chinese_traditional": "寫", "basic_japanese_definition": "文字や絵を手でかくことをあらわす動詞。", "example_sentences": [{ "jp": "名前を書いてください。", "kana": "なまえをかいてください。", "zh": "请写名字。" }], "grammar_patterns": ["pt-017"], "chinese_learner_note": "画画也用同音的 描く/書く（かく）。", "audio_url": null, "tags": ["verb", "communication", "core"], "review": "verified" },
  { "id": "vb-024", "lemma": "教える", "kana": "おしえる", "kanji": "教える", "romaji": "oshieru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "教；告诉", "chinese_traditional": "教；告訴", "basic_japanese_definition": "知っていることを人につたえることをあらわす動詞。", "example_sentences": [{ "jp": "電話番号を教えてください。", "kana": "でんわばんごうをおしえてください。", "zh": "请告诉我电话号码。" }], "grammar_patterns": [], "chinese_learner_note": "兼表「教（知识）」和「告诉（信息）」；对象用 に。", "audio_url": null, "tags": ["verb", "communication"], "review": "verified" },
  { "id": "vb-025", "lemma": "習う", "kana": "ならう", "kanji": "習う", "romaji": "narau", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "学习（向人学）", "chinese_traditional": "學習（向人學）", "basic_japanese_definition": "先生などから何かをならうことをあらわす動詞。", "example_sentences": [{ "jp": "先生に日本語を習います。", "kana": "せんせいににほんごをならいます。", "zh": "跟老师学日语。" }], "grammar_patterns": [], "chinese_learner_note": "習う 强调「跟人学（技能）」；勉強する 偏「自己用功」；学ぶ 较书面。", "audio_url": null, "tags": ["verb", "communication"], "review": "verified" },
  { "id": "vb-026", "lemma": "答える", "kana": "こたえる", "kanji": "答える", "romaji": "kotaeru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "communication", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "回答", "chinese_traditional": "回答", "basic_japanese_definition": "質問に返事をすることをあらわす動詞。", "example_sentences": [{ "jp": "質問に答えます。", "kana": "しつもんにこたえます。", "zh": "回答问题。" }], "grammar_patterns": [], "chinese_learner_note": "回答的对象用 に（質問に答える）。", "audio_url": null, "tags": ["verb", "communication"], "review": "verified" },
  { "id": "vb-027", "lemma": "使う", "kana": "つかう", "kanji": "使う", "romaji": "tsukau", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "用；使用", "chinese_traditional": "用；使用", "basic_japanese_definition": "道具やお金などをつかうことをあらわす動詞。", "example_sentences": [{ "jp": "はしを使って食べます。", "kana": "はしをつかってたべます。", "zh": "用筷子吃。" }], "grammar_patterns": [], "chinese_learner_note": "使い方＝用法（高频名词）。", "audio_url": null, "tags": ["verb", "core"], "review": "verified" },
  { "id": "vb-028", "lemma": "作る", "kana": "つくる", "kanji": "作る", "romaji": "tsukuru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "做；制作", "chinese_traditional": "做；製作", "basic_japanese_definition": "材料から何かを新しく作りだすことをあらわす動詞。", "example_sentences": [{ "jp": "料理を作ります。", "kana": "りょうりをつくります。", "zh": "做菜。" }], "grammar_patterns": [], "chinese_learner_note": "作る＝制作（具体物/料理）；する＝做（动作/事情），不要混。", "audio_url": null, "tags": ["verb", "core"], "review": "verified" },
  { "id": "vb-029", "lemma": "取る", "kana": "とる", "kanji": "取る", "romaji": "toru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "拿；取", "chinese_traditional": "拿；取", "basic_japanese_definition": "手でものをとることをあらわす動詞。", "example_sentences": [{ "jp": "塩を取ってください。", "kana": "しおをとってください。", "zh": "请把盐递给我。" }], "grammar_patterns": [], "chinese_learner_note": "同音 撮る＝拍照（写真を撮る），汉字不同。", "audio_url": null, "tags": ["verb"], "review": "verified" },
  { "id": "vb-030", "lemma": "持つ", "kana": "もつ", "kanji": "持つ", "romaji": "motsu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "拿着；持有", "chinese_traditional": "拿著；持有", "basic_japanese_definition": "手でもつ、または自分のものとして持っていることをあらわす動詞。", "example_sentences": [{ "jp": "かばんを持っています。", "kana": "かばんをもっています。", "zh": "拿着包。" }], "grammar_patterns": ["pt-018"], "chinese_learner_note": "持っている＝拿着/拥有（状态）。「带（去）」常说 持って行く。", "audio_url": null, "tags": ["verb"], "review": "verified" },
  { "id": "vb-031", "lemma": "開ける", "kana": "あける", "kanji": "開ける", "romaji": "akeru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "打开（他动）", "chinese_traditional": "打開（他動）", "basic_japanese_definition": "ドアやまどなどをあけることをあらわす動詞（人がする）。", "example_sentences": [{ "jp": "窓を開けます。", "kana": "まどをあけます。", "zh": "（我）开窗。" }], "grammar_patterns": [], "chinese_learner_note": "他动词 開ける（人开）↔ 自动词 開く（门自己开）。日语自他成对，须分清。", "audio_url": null, "tags": ["verb", "transitive"], "review": "verified" },
  { "id": "vb-032", "lemma": "閉める", "kana": "しめる", "kanji": "閉める", "romaji": "shimeru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "关上（他动）", "chinese_traditional": "關上（他動）", "basic_japanese_definition": "ドアやまどなどをしめることをあらわす動詞（人がする）。", "example_sentences": [{ "jp": "ドアを閉めてください。", "kana": "ドアをしめてください。", "zh": "请关门。" }], "grammar_patterns": [], "chinese_learner_note": "他动词 閉める ↔ 自动词 閉まる。与 開ける/開く 两对一起记。", "audio_url": null, "tags": ["verb", "transitive"], "review": "verified" },
  { "id": "vb-033", "lemma": "入れる", "kana": "いれる", "kanji": "入れる", "romaji": "ireru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["入"], "chinese_simplified": "放入；加入（他动）", "chinese_traditional": "放入；加入（他動）", "basic_japanese_definition": "ものを中に入れることをあらわす動詞（人がする）。", "example_sentences": [{ "jp": "かばんに本を入れます。", "kana": "かばんにほんをいれます。", "zh": "把书放进包里。" }], "grammar_patterns": [], "chinese_learner_note": "他动词 入れる（放进）↔ 自动词 入る（はいる，进入）。", "audio_url": null, "tags": ["verb", "transitive"], "review": "verified" },
  { "id": "vb-034", "lemma": "入る", "kana": "はいる", "kanji": "入る", "romaji": "hairu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["入"], "chinese_simplified": "进入（自动）", "chinese_traditional": "進入（自動）", "basic_japanese_definition": "中へはいることをあらわす動詞。", "example_sentences": [{ "jp": "部屋に入ります。", "kana": "へやにはいります。", "zh": "进房间。" }], "grammar_patterns": [], "chinese_learner_note": "读 はいる（不是 いる）；是例外五段。进入的场所用 に。", "audio_url": null, "tags": ["verb", "motion", "intransitive"], "review": "verified" },
  { "id": "vb-035", "lemma": "出る", "kana": "でる", "kanji": "出る", "romaji": "deru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "motion", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["出"], "chinese_simplified": "出去；出来（自动）", "chinese_traditional": "出去；出來（自動）", "basic_japanese_definition": "中から外へ出ることをあらわす動詞。", "example_sentences": [{ "jp": "七時に家を出ます。", "kana": "しちじにいえをでます。", "zh": "七点出门。" }], "grammar_patterns": [], "chinese_learner_note": "自动词 出る ↔ 他动词 出す（拿出/寄出）。离开的地点用 を（家を出る）。", "audio_url": null, "tags": ["verb", "motion", "intransitive"], "review": "verified" },
  { "id": "vb-036", "lemma": "出す", "kana": "だす", "kanji": "出す", "romaji": "dasu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["出"], "chinese_simplified": "拿出；寄出；交（他动）", "chinese_traditional": "拿出；寄出；交（他動）", "basic_japanese_definition": "中のものを外に出すことをあらわす動詞（人がする）。", "example_sentences": [{ "jp": "手紙を出します。", "kana": "てがみをだします。", "zh": "寄信。" }], "grammar_patterns": [], "chinese_learner_note": "兼表「拿出/寄出/交（作业）」；他动词，与自动词 出る 成对。", "audio_url": null, "tags": ["verb", "transitive"], "review": "verified" },
  { "id": "vb-037", "lemma": "置く", "kana": "おく", "kanji": "置く", "romaji": "oku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "action-handling", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "放；搁置", "chinese_traditional": "放；擱置", "basic_japanese_definition": "ものをある場所にそっと置くことをあらわす動詞。", "example_sentences": [{ "jp": "机の上に置いてください。", "kana": "つくえのうえにおいてください。", "zh": "请放在桌上。" }], "grammar_patterns": [], "chinese_learner_note": "「Vておく」＝事先做好（补助动词用法，如 買っておく）。", "audio_url": null, "tags": ["verb"], "review": "verified" },
  { "id": "vb-038", "lemma": "開く", "kana": "あく", "kanji": "開く", "romaji": "aku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "change-result", "jlpt_ref": "N5", "frequency_band": 3, "core_kanji": [], "chinese_simplified": "开（自动）", "chinese_traditional": "開（自動）", "basic_japanese_definition": "ドアや店などがあくことをあらわす動詞（ひとりでにあく）。", "example_sentences": [{ "jp": "ドアが開きました。", "kana": "ドアがあきました。", "zh": "门开了。" }], "grammar_patterns": [], "chinese_learner_note": "自动词（门自己开）；同汉字「開く」也可读 ひらく。与他动词 開ける 成对。", "audio_url": null, "tags": ["verb", "intransitive"], "review": "verified" },
  { "id": "vb-039", "lemma": "閉まる", "kana": "しまる", "kanji": "閉まる", "romaji": "shimaru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "change-result", "jlpt_ref": "N5", "frequency_band": 3, "core_kanji": [], "chinese_simplified": "关（自动）", "chinese_traditional": "關（自動）", "basic_japanese_definition": "ドアや店などがしまることをあらわす動詞。", "example_sentences": [{ "jp": "店は八時に閉まります。", "kana": "みせははちじにしまります。", "zh": "店八点关门。" }], "grammar_patterns": [], "chinese_learner_note": "自动词，与他动词 閉める 成对。", "audio_url": null, "tags": ["verb", "intransitive"], "review": "verified" },
  { "id": "vb-040", "lemma": "あげる", "kana": "あげる", "kanji": null, "romaji": "ageru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "给（我→别人）", "chinese_traditional": "給（我→別人）", "basic_japanese_definition": "自分やだれかが、ほかの人にものをあげることをあらわす動詞。", "example_sentences": [{ "jp": "友達にプレゼントをあげます。", "kana": "ともだちにプレゼントをあげます。", "zh": "给朋友礼物。" }], "grammar_patterns": [], "chinese_learner_note": "授受动词：あげる＝我/某人给别人；くれる＝别人给我；もらう＝（我）从别人得到。方向不能搞反。", "audio_url": null, "tags": ["verb", "transfer", "giving-receiving"], "review": "verified" },
  { "id": "vb-041", "lemma": "もらう", "kana": "もらう", "kanji": null, "romaji": "morau", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "得到；收到", "chinese_traditional": "得到；收到", "basic_japanese_definition": "人から何かをもらうことをあらわす動詞。", "example_sentences": [{ "jp": "母にお金をもらいました。", "kana": "ははにおかねをもらいました。", "zh": "从妈妈那里得到了钱。" }], "grammar_patterns": [], "chinese_learner_note": "给予者用 に/から（母にもらう）；以「我」为接受方。", "audio_url": null, "tags": ["verb", "transfer", "giving-receiving"], "review": "verified" },
  { "id": "vb-042", "lemma": "くれる", "kana": "くれる", "kanji": null, "romaji": "kureru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "给（别人→我）", "chinese_traditional": "給（別人→我）", "basic_japanese_definition": "ほかの人が自分（やうちの人）に何かをくれることをあらわす動詞。", "example_sentences": [{ "jp": "友達が本をくれました。", "kana": "ともだちがほんをくれました。", "zh": "朋友给了我书。" }], "grammar_patterns": [], "chinese_learner_note": "くれる 的接受方必须是「我方」；同样是「给」，给别人用 あげる，给我用 くれる。", "audio_url": null, "tags": ["verb", "transfer", "giving-receiving"], "review": "verified" },
  { "id": "vb-043", "lemma": "買う", "kana": "かう", "kanji": "買う", "romaji": "kau", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["買"], "chinese_simplified": "买", "chinese_traditional": "買", "basic_japanese_definition": "お金をはらってものを手に入れることをあらわす動詞。", "example_sentences": [{ "jp": "店でパンを買います。", "kana": "みせでパンをかいます。", "zh": "在店里买面包。" }], "grammar_patterns": [], "chinese_learner_note": "买东西的场所用 で。与 売る（卖）成对。", "audio_url": null, "tags": ["verb", "transfer", "core"], "review": "verified" },
  { "id": "vb-044", "lemma": "売る", "kana": "うる", "kanji": "売る", "romaji": "uru", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": ["売"], "chinese_simplified": "卖", "chinese_traditional": "賣", "basic_japanese_definition": "お金をもらってものをわたすことをあらわす動詞。", "example_sentences": [{ "jp": "あの店は野菜を売っています。", "kana": "あのみせはやさいをうっています。", "zh": "那家店卖蔬菜。" }], "grammar_patterns": [], "chinese_learner_note": "与 買う 成对；自动词「売れる」＝畅销/卖得出去。", "audio_url": null, "tags": ["verb", "transfer"], "review": "verified" },
  { "id": "vb-045", "lemma": "借りる", "kana": "かりる", "kanji": "借りる", "romaji": "kariru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "借（入）", "chinese_traditional": "借（入）", "basic_japanese_definition": "人からものをかりることをあらわす動詞。", "example_sentences": [{ "jp": "図書館で本を借ります。", "kana": "としょかんでほんをかります。", "zh": "在图书馆借书。" }], "grammar_patterns": [], "chinese_learner_note": "中文「借」不分方向，日语 借りる＝借入、貸す＝借出，必须分开。", "audio_url": null, "tags": ["verb", "transfer"], "review": "verified" },
  { "id": "vb-046", "lemma": "貸す", "kana": "かす", "kanji": "貸す", "romaji": "kasu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "借（出）；借给", "chinese_traditional": "借（出）；借給", "basic_japanese_definition": "自分のものを人にかすことをあらわす動詞。", "example_sentences": [{ "jp": "ペンを貸してください。", "kana": "ペンをかしてください。", "zh": "请把笔借给我。" }], "grammar_patterns": [], "chinese_learner_note": "貸す＝借出（给别人）；与 借りる（借入）方向相反。", "audio_url": null, "tags": ["verb", "transfer"], "review": "verified" },
  { "id": "vb-047", "lemma": "払う", "kana": "はらう", "kanji": "払う", "romaji": "harau", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "transfer", "jlpt_ref": "N4", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "付（钱）", "chinese_traditional": "付（錢）", "basic_japanese_definition": "お金をはらうことをあらわす動詞。", "example_sentences": [{ "jp": "お金を払います。", "kana": "おかねをはらいます。", "zh": "付钱。" }], "grammar_patterns": [], "chinese_learner_note": "支払う 是更正式的「支付」。", "audio_url": null, "tags": ["verb", "transfer", "money"], "review": "verified" },
  { "id": "vb-048", "lemma": "食べる", "kana": "たべる", "kanji": "食べる", "romaji": "taberu", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["食"], "chinese_simplified": "吃", "chinese_traditional": "吃", "basic_japanese_definition": "食べものを口に入れて食べることをあらわす動詞。", "example_sentences": [{ "jp": "朝ご飯を食べます。", "kana": "あさごはんをたべます。", "zh": "吃早饭。" }], "grammar_patterns": ["pt-010"], "chinese_learner_note": "粗俗/男性口语用 食う（くう）。", "audio_url": null, "tags": ["verb", "food", "core"], "review": "verified" },
  { "id": "vb-049", "lemma": "飲む", "kana": "のむ", "kanji": "飲む", "romaji": "nomu", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["飲"], "chinese_simplified": "喝；吃（药）", "chinese_traditional": "喝；吃（藥）", "basic_japanese_definition": "水やお茶などを飲むことをあらわす動詞。", "example_sentences": [{ "jp": "お茶を飲みます。", "kana": "おちゃをのみます。", "zh": "喝茶。" }, { "jp": "薬を飲みます。", "kana": "くすりをのみます。", "zh": "吃药。" }], "grammar_patterns": [], "chinese_learner_note": "「吃药」在日语用 飲む（不是 食べる）；お酒を飲む＝喝酒/应酬。", "audio_url": null, "tags": ["verb", "food", "core"], "review": "verified" },
  { "id": "vb-050", "lemma": "寝る", "kana": "ねる", "kanji": "寝る", "romaji": "neru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "睡觉；躺", "chinese_traditional": "睡覺；躺", "basic_japanese_definition": "よこになって、ねむることをあらわす動詞。", "example_sentences": [{ "jp": "十一時に寝ます。", "kana": "じゅういちじにねます。", "zh": "十一点睡觉。" }], "grammar_patterns": [], "chinese_learner_note": "寝る 侧重「上床/躺下睡」；眠る（ねむる）侧重「入睡」。", "audio_url": null, "tags": ["verb", "daily", "core"], "review": "verified" },
  { "id": "vb-051", "lemma": "起きる", "kana": "おきる", "kanji": "起きる", "romaji": "okiru", "part_of_speech": "verb-ichidan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "起床；发生", "chinese_traditional": "起床；發生", "basic_japanese_definition": "ねていた人がおきることをあらわす動詞。事がおこる意味もある。", "example_sentences": [{ "jp": "毎朝六時に起きます。", "kana": "まいあさろくじにおきます。", "zh": "每天早上六点起床。" }], "grammar_patterns": [], "chinese_learner_note": "也表「（事件）发生」（事故が起きる）；与 寝る 成对。", "audio_url": null, "tags": ["verb", "daily", "core"], "review": "verified" },
  { "id": "vb-052", "lemma": "働く", "kana": "はたらく", "kanji": "働く", "romaji": "hataraku", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "工作；劳动", "chinese_traditional": "工作；勞動", "basic_japanese_definition": "お金をもらって仕事をすることをあらわす動詞。", "example_sentences": [{ "jp": "銀行で働いています。", "kana": "ぎんこうではたらいています。", "zh": "在银行工作。" }], "grammar_patterns": ["pt-018"], "chinese_learner_note": "工作场所用 で。「働」是日本自造汉字（国字），中文没有。", "audio_url": null, "tags": ["verb", "daily"], "review": "verified" },
