  { "id": "vb-055", "lemma": "会う", "kana": "あう", "kanji": "会う", "romaji": "au", "part_of_speech": "verb-godan", "category": "verbs", "subcategory": "daily-life", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["会"], "chinese_simplified": "见面；遇见", "chinese_traditional": "見面；遇見", "basic_japanese_definition": "人と人がいっしょになる、会うことをあらわす動詞。", "example_sentences": [{ "jp": "駅で友達に会いました。", "kana": "えきでともだちにあいました。", "zh": "在车站遇到了朋友。" }], "grammar_patterns": [], "chinese_learner_note": "见面对象用 に（友達に会う），不用 を。", "audio_url": null, "tags": ["verb", "daily"], "review": "verified" },
