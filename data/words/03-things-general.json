[
  { "id": "tg-001", "lemma": "こと", "kana": "こと", "kanji": null, "romaji": "koto", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "事情；事（抽象）", "chinese_traditional": "事情；事（抽象）", "basic_japanese_definition": "目に見えない、ことがらをあらわす言葉。動詞を名詞にするときにも使う。", "example_sentences": [{ "jp": "大切なことを話します。", "kana": "たいせつなことをはなします。", "zh": "说重要的事。" }], "grammar_patterns": ["pt-031", "pt-040"], "chinese_learner_note": "こと 指抽象的「事」；もの 指具体的「物」。「Vること」把动词名词化（构句力极强）。", "audio_url": null, "tags": ["formal-noun", "core"], "review": "verified" },
  { "id": "tg-002", "lemma": "もの", "kana": "もの", "kanji": null, "romaji": "mono", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "东西；物（具体）", "chinese_traditional": "東西；物（具體）", "basic_japanese_definition": "手にとれる、目に見えるもの。", "example_sentences": [{ "jp": "おいしいものを食べたいです。", "kana": "おいしいものをたべたいです。", "zh": "想吃好吃的东西。" }], "grammar_patterns": [], "chinese_learner_note": "もの＝具体的物；こと＝抽象的事。汉字写 物 / 者（者指人）。", "audio_url": null, "tags": ["formal-noun", "core"], "review": "verified" },
  { "id": "tg-003", "lemma": "ところ", "kana": "ところ", "kanji": null, "romaji": "tokoro", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "地方；地点；…的时候", "chinese_traditional": "地方；地點；…的時候", "basic_japanese_definition": "場所をあらわす言葉。「ちょうど〜する時」の意味でも使う。", "example_sentences": [{ "jp": "静かなところに住みたいです。", "kana": "しずかなところにすみたいです。", "zh": "想住在安静的地方。" }], "grammar_patterns": [], "chinese_learner_note": "汉字 所；口语可缩 とこ。也表时间点（今、出るところ＝正要出门）。", "audio_url": null, "tags": ["formal-noun", "place", "core"], "review": "verified" },
  { "id": "tg-004", "lemma": "とき", "kana": "とき", "kanji": "時", "romaji": "toki", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["時"], "chinese_simplified": "时候；…的时候", "chinese_traditional": "時候；…的時候", "basic_japanese_definition": "あることがおこる、その時をあらわす言葉。", "example_sentences": [{ "jp": "子供のとき、よく遊びました。", "kana": "こどものとき、よくあそびました。", "zh": "小时候经常玩。" }], "grammar_patterns": [], "chinese_learner_note": "「〜とき」表示「…的时候」，是 N5 核心语法（动词原形/た形＋とき意义不同）。", "audio_url": null, "tags": ["formal-noun", "time", "core"], "review": "verified" },
  { "id": "tg-005", "lemma": "はず", "kana": "はず", "kanji": null, "romaji": "hazu", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N4", "frequency_band": 3, "core_kanji": [], "chinese_simplified": "应该；理应", "chinese_traditional": "應該；理應", "basic_japanese_definition": "とうぜんそうなるだろう、と思うことをあらわす言葉。", "example_sentences": [{ "jp": "彼は来るはずです。", "kana": "かれはくるはずです。", "zh": "他应该会来。" }], "grammar_patterns": [], "chinese_learner_note": "表「根据道理推断应该…」；与「べき（义务上应该）」不同。", "audio_url": null, "tags": ["formal-noun"], "review": "verified" },
  { "id": "tg-006", "lemma": "つもり", "kana": "つもり", "kanji": null, "romaji": "tsumori", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N4", "frequency_band": 3, "core_kanji": [], "chinese_simplified": "打算；意图", "chinese_traditional": "打算；意圖", "basic_japanese_definition": "これからしようと思っている考え。", "example_sentences": [{ "jp": "明日休むつもりです。", "kana": "あしたやすむつもりです。", "zh": "打算明天休息。" }], "grammar_patterns": ["pt-046"], "chinese_learner_note": "「動詞原形＋つもり」表打算；否定 〜ないつもり。", "audio_url": null, "tags": ["formal-noun", "intention"], "review": "verified" },
  { "id": "tg-007", "lemma": "ため", "kana": "ため", "kanji": null, "romaji": "tame", "part_of_speech": "noun", "category": "things-general", "subcategory": "formal-noun", "jlpt_ref": "N4", "frequency_band": 3, "core_kanji": [], "chinese_simplified": "为了；因为", "chinese_traditional": "為了；因為", "basic_japanese_definition": "目的や理由をあらわす言葉。", "example_sentences": [{ "jp": "健康のために運動します。", "kana": "けんこうのためにうんどうします。", "zh": "为了健康而运动。" }], "grammar_patterns": [], "chinese_learner_note": "「Nのため(に)」「Vるため(に)」表目的；也可表原因。", "audio_url": null, "tags": ["formal-noun"], "review": "verified" },
  { "id": "tg-008", "lemma": "人", "kana": "ひと", "kanji": "人", "romaji": "hito", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["人"], "chinese_simplified": "人", "chinese_traditional": "人", "basic_japanese_definition": "わたしたち、にんげんをあらわす言葉。", "example_sentences": [{ "jp": "あの人は誰ですか。", "kana": "あのひとはだれですか。", "zh": "那个人是谁？" }], "grammar_patterns": [], "chinese_learner_note": "训读 ひと；音读 じん/にん 多用于词中（日本人・三人）。", "audio_url": null, "tags": ["people", "core"], "review": "verified" },
  { "id": "tg-009", "lemma": "子供", "kana": "こども", "kanji": "子供", "romaji": "kodomo", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["子"], "chinese_simplified": "孩子；小孩", "chinese_traditional": "孩子；小孩", "basic_japanese_definition": "年がわかい、小さい人。じぶんの子の意味もある。", "example_sentences": [{ "jp": "子供が二人います。", "kana": "こどもがふたりいます。", "zh": "有两个孩子。" }], "grammar_patterns": [], "chinese_learner_note": "兼指「儿童」与「自己的子女」。反义 大人（おとな）。", "audio_url": null, "tags": ["people", "core"], "review": "verified" },
  { "id": "tg-010", "lemma": "家族", "kana": "かぞく", "kanji": "家族", "romaji": "kazoku", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "家人；家庭", "chinese_traditional": "家人；家庭", "basic_japanese_definition": "いっしょにくらす、ちかい人たち。", "example_sentences": [{ "jp": "家族は四人です。", "kana": "かぞくはよにんです。", "zh": "家里有四口人。" }], "grammar_patterns": [], "chinese_learner_note": "说别人家庭礼貌加 ご（ご家族）。", "audio_url": null, "tags": ["people", "core"], "review": "verified" },
  { "id": "tg-011", "lemma": "友達", "kana": "ともだち", "kanji": "友達", "romaji": "tomodachi", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["友"], "chinese_simplified": "朋友", "chinese_traditional": "朋友", "basic_japanese_definition": "なかのいい人。", "example_sentences": [{ "jp": "友達と映画を見ます。", "kana": "ともだちとえいがをみます。", "zh": "和朋友看电影。" }], "grammar_patterns": [], "chinese_learner_note": "「和朋友（一起）」用 と。", "audio_url": null, "tags": ["people", "core"], "review": "verified" },
  { "id": "tg-012", "lemma": "先生", "kana": "せんせい", "kanji": "先生", "romaji": "sensei", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["先", "生"], "chinese_simplified": "老师；医生（敬称）", "chinese_traditional": "老師；醫生（敬稱）", "basic_japanese_definition": "教える人。医者などをよぶときにも使う。", "example_sentences": [{ "jp": "田中先生は親切です。", "kana": "たなかせんせいはしんせつです。", "zh": "田中老师很亲切。" }], "grammar_patterns": [], "chinese_learner_note": "先生≠中文「先生（丈夫/Mr.）」；日语用于老师、医生、律师等。不用于普通成年男子。", "audio_url": null, "tags": ["people", "false-friend", "core"], "review": "verified" },
  { "id": "tg-013", "lemma": "学生", "kana": "がくせい", "kanji": "学生", "romaji": "gakusei", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["学", "生"], "chinese_simplified": "学生", "chinese_traditional": "學生", "basic_japanese_definition": "学校で勉強する人。", "example_sentences": [{ "jp": "私は大学の学生です。", "kana": "わたしはだいがくのがくせいです。", "zh": "我是大学生。" }], "grammar_patterns": ["pt-001"], "chinese_learner_note": "学生 多指大学生；中小学生常说 生徒（せいと）。", "audio_url": null, "tags": ["people", "core"], "review": "verified" },
  { "id": "tg-014", "lemma": "名前", "kana": "なまえ", "kanji": "名前", "romaji": "namae", "part_of_speech": "noun", "category": "things-general", "subcategory": "people-relations", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["名", "前"], "chinese_simplified": "名字；名称", "chinese_traditional": "名字；名稱", "basic_japanese_definition": "人やものをよぶときの言葉。", "example_sentences": [{ "jp": "お名前は何ですか。", "kana": "おなまえはなんですか。", "zh": "您叫什么名字？" }], "grammar_patterns": [], "chinese_learner_note": "问别人名字礼貌加 お（お名前）。", "audio_url": null, "tags": ["abstract", "core"], "review": "verified" },
  { "id": "tg-015", "lemma": "時間", "kana": "じかん", "kanji": "時間", "romaji": "jikan", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["時", "間"], "chinese_simplified": "时间；…小时", "chinese_traditional": "時間；…小時", "basic_japanese_definition": "時のながれ、またはその長さ。", "example_sentences": [{ "jp": "時間がありません。", "kana": "じかんがありません。", "zh": "没有时间。" }, { "jp": "三時間勉強しました。", "kana": "さんじかんべんきょうしました。", "zh": "学习了三个小时。" }], "grammar_patterns": [], "chinese_learner_note": "時間 也作时长量词（三時間＝三小时）；时刻点用 〜時（三時＝三点）。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-016", "lemma": "今", "kana": "いま", "kanji": "今", "romaji": "ima", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["今"], "chinese_simplified": "现在", "chinese_traditional": "現在", "basic_japanese_definition": "ちょうど、この時。", "example_sentences": [{ "jp": "今、何時ですか。", "kana": "いま、なんじですか。", "zh": "现在几点？" }], "grammar_patterns": [], "chinese_learner_note": null, "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-017", "lemma": "今日", "kana": "きょう", "kanji": "今日", "romaji": "kyō", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["今", "日"], "chinese_simplified": "今天", "chinese_traditional": "今天", "basic_japanese_definition": "この日。", "example_sentences": [{ "jp": "今日は金曜日です。", "kana": "きょうはきんようびです。", "zh": "今天是星期五。" }], "grammar_patterns": [], "chinese_learner_note": "特殊读音 きょう（不读 こんにち，除非「今日(こんにち)」书面）。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-018", "lemma": "明日", "kana": "あした", "kanji": "明日", "romaji": "ashita", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "明天", "chinese_traditional": "明天", "basic_japanese_definition": "今日のつぎの日。", "example_sentences": [{ "jp": "明日、また来ます。", "kana": "あした、またきます。", "zh": "明天再来。" }], "grammar_patterns": [], "chinese_learner_note": "可读 あした（口语）/ あす（稍正式）/ みょうにち（很正式）。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-019", "lemma": "昨日", "kana": "きのう", "kanji": "昨日", "romaji": "kinō", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["日"], "chinese_simplified": "昨天", "chinese_traditional": "昨天", "basic_japanese_definition": "今日の前の日。", "example_sentences": [{ "jp": "昨日は雨でした。", "kana": "きのうはあめでした。", "zh": "昨天下雨了。" }], "grammar_patterns": [], "chinese_learner_note": "特殊读音 きのう。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-020", "lemma": "朝", "kana": "あさ", "kanji": "朝", "romaji": "asa", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "早上；早晨", "chinese_traditional": "早上；早晨", "basic_japanese_definition": "一日のはじめの、あかるくなるころ。", "example_sentences": [{ "jp": "朝、コーヒーを飲みます。", "kana": "あさ、コーヒーをのみます。", "zh": "早上喝咖啡。" }], "grammar_patterns": [], "chinese_learner_note": "今朝（けさ）＝今天早上（特殊读音）。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-021", "lemma": "昼", "kana": "ひる", "kanji": "昼", "romaji": "hiru", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": [], "chinese_simplified": "中午；白天", "chinese_traditional": "中午；白天", "basic_japanese_definition": "一日のまん中、ひるま。", "example_sentences": [{ "jp": "昼ご飯を食べます。", "kana": "ひるごはんをたべます。", "zh": "吃午饭。" }], "grammar_patterns": [], "chinese_learner_note": "昼ご飯＝午饭；お昼＝中午/午饭。", "audio_url": null, "tags": ["time"], "review": "verified" },
  { "id": "tg-022", "lemma": "夜", "kana": "よる", "kanji": "夜", "romaji": "yoru", "part_of_speech": "noun", "category": "things-general", "subcategory": "time", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": [], "chinese_simplified": "晚上；夜", "chinese_traditional": "晚上；夜", "basic_japanese_definition": "暗くなってからの時間。", "example_sentences": [{ "jp": "夜は星がきれいです。", "kana": "よるはほしがきれいです。", "zh": "晚上星星很美。" }], "grammar_patterns": [], "chinese_learner_note": "晚饭 晩ご飯（ばんごはん）用 晩；夜 与 晩 略有分工。", "audio_url": null, "tags": ["time", "core"], "review": "verified" },
  { "id": "tg-023", "lemma": "上", "kana": "うえ", "kanji": "上", "romaji": "ue", "part_of_speech": "noun", "category": "things-general", "subcategory": "place-direction", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["上"], "chinese_simplified": "上；上面", "chinese_traditional": "上；上面", "basic_japanese_definition": "高いほう、上のほうの場所。", "example_sentences": [{ "jp": "机の上に本があります。", "kana": "つくえのうえにほんがあります。", "zh": "桌上有书。" }], "grammar_patterns": ["pt-009"], "chinese_learner_note": "方位名词用「Nの上」结构。反义 下。", "audio_url": null, "tags": ["place", "core"], "review": "verified" },
  { "id": "tg-024", "lemma": "下", "kana": "した", "kanji": "下", "romaji": "shita", "part_of_speech": "noun", "category": "things-general", "subcategory": "place-direction", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["下"], "chinese_simplified": "下；下面", "chinese_traditional": "下；下面", "basic_japanese_definition": "低いほう、下のほうの場所。", "example_sentences": [{ "jp": "机の下に猫がいます。", "kana": "つくえのしたにねこがいます。", "zh": "桌子下有猫。" }], "grammar_patterns": ["pt-009"], "chinese_learner_note": "反义 上。", "audio_url": null, "tags": ["place", "core"], "review": "verified" },
  { "id": "tg-025", "lemma": "中", "kana": "なか", "kanji": "中", "romaji": "naka", "part_of_speech": "noun", "category": "things-general", "subcategory": "place-direction", "jlpt_ref": "N5", "frequency_band": 1, "core_kanji": ["中"], "chinese_simplified": "里面；中间", "chinese_traditional": "裡面；中間", "basic_japanese_definition": "ものの内がわ、まん中。", "example_sentences": [{ "jp": "かばんの中に何がありますか。", "kana": "かばんのなかになにがありますか。", "zh": "包里有什么？" }], "grammar_patterns": ["pt-009"], "chinese_learner_note": "训读 なか＝里面/中间；与「外（そと）」相对。", "audio_url": null, "tags": ["place", "core"], "review": "verified" },
  { "id": "tg-026", "lemma": "外", "kana": "そと", "kanji": "外", "romaji": "soto", "part_of_speech": "noun", "category": "things-general", "subcategory": "place-direction", "jlpt_ref": "N5", "frequency_band": 2, "core_kanji": ["外"], "chinese_simplified": "外面", "chinese_traditional": "外面", "basic_japanese_definition": "ものの外がわ、たてものの外。", "example_sentences": [{ "jp": "外で遊びます。", "kana": "そとであそびます。", "zh": "在外面玩。" }], "grammar_patterns": [], "chinese_learner_note": "反义 中。", "audio_url": null, "tags": ["place"], "review": "verified" },
